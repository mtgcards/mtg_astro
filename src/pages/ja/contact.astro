---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE_URL } from '@/lib/constants';
import { t } from '@/lib/i18n';
import ContactForm from '@/components/react/ContactForm';
export const prerender = true;

import BreadcrumbJsonLd from '@/components/astro/BreadcrumbJsonLd.astro';

const pageUrl = '/ja/contact';
const homeUrl = `${SITE_URL}/ja/`;
const contactUrl = `${SITE_URL}${pageUrl}`;
---

<BaseLayout
  title={t('contact.title')}
  description={t('contact.description')}
  canonical={pageUrl}
  ogImage="/og/contact.png"
>
  <main>
    <BreadcrumbJsonLd
      items={[
        { name: t('nav.home'), url: homeUrl },
        { name: t('contact.title'), url: contactUrl },
      ]}
    />
    <div class="static-page">
      <h1>{t('contact.title')}</h1>
      <p>{t('contact.description')}</p>
      <ContactForm client:load />
      <a href="/ja" class="back-link">
        {t('common.backToHome')}
      </a>
    </div>
  </main>
</BaseLayout>
