---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { DEFAULT_FORMAT, SITE_URL } from '@/lib/constants';
import { loadCardsForFormat } from '@/lib/cards';
import { t, tHas } from '@/lib/i18n';
import CardGrid from '@/components/react/CardGrid';
import TabBar from '@/components/react/TabBar';
import ItemListJsonLd from '@/components/astro/ItemListJsonLd.astro';
import BreadcrumbJsonLd from '@/components/astro/BreadcrumbJsonLd.astro';
import { filterCardsByThreshold } from '@/lib/utils';
import { DEFAULT_THRESHOLDS } from '@/lib/constants';

export const prerender = true;

const format = DEFAULT_FORMAT;
const cards = loadCardsForFormat(format);
const label = t(`formats.${format}`);
const pageUrl = '/ja';
const currentUrl = `${SITE_URL}${pageUrl}`;
const homeUrl = `${SITE_URL}/ja/`;
const listName = tHas(`formatPageTitles.${format}`)
  ? t(`formatPageTitles.${format}`)
  : t('formatPageTitles.default', { label });
const defaultFilteredCards = filterCardsByThreshold(cards, format, DEFAULT_THRESHOLDS);
---

<BaseLayout
  title={listName}
  description={t(`formatDescriptions.${format}`)}
  canonical={pageUrl}
  ogImage={`/og/${format}.png`}
>
  <main>
    <ItemListJsonLd name={listName} url={currentUrl} cards={defaultFilteredCards} />
    <BreadcrumbJsonLd
      items={[
        { name: t('nav.home'), url: homeUrl },
        { name: label, url: currentUrl },
      ]}
    />
    <div class="top-bar">
      <div class="header-compact">
        <h1>{t('site.name')}</h1>
      </div>
      <TabBar activeFormat={format} client:load />
      <CardGrid cards={cards} format={format} client:load />
    </div>
  </main>
</BaseLayout>
