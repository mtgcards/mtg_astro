{
  "theme": "Default",
  "coreTools": [
    "read_file",
    "write_file",
    "run_shell_command",
    "list_directory",
    "search_files"
  ],
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run deploy)",
      "Bash(npm run test)",
      "Bash(npm run lint)",
      "Bash(npm install*)",
      "Bash(node scripts/*.js)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(mkdir*)",
      "Bash(cp*)",
      "Bash(mv*)",
      "Bash(rm*)",
      "Bash(ln*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(curl*)",
      "Bash(wrangler*)",
      "Bash(npx*)",
      "Bash(npx astro*)",
      "Bash(npm run*)",
      "Bash(npm install)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)"
    ]
  }
}
