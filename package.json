{
  "name": "mtgcards-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/prebuild.js",
    "build": "npm run prebuild && astro build && npm run og:generate",
    "preview": "astro preview",
    "lint": "eslint",
    "pretest": "playwright install chromium",
    "test": "playwright test",
    "og:generate": "node scripts/generate-og-images.js",
    "deploy": "astro build && wrangler deploy"
  },
  "dependencies": {
    "astro": "^6.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@astrojs/cloudflare": "^12.0.0",
    "@astrojs/react": "^4.0.0",
    "@astrojs/sitemap": "^3.2.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "satori": "^0.12.0",
    "@resvg/resvg-js": "^2.6.2",
    "stream-chain": "^2.2.5",
    "stream-json": "^1.9.1",
    "typescript": "^5",
    "wrangler": "^4.69.0"
  }
}
